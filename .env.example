# ============================================================
# Agent Forge — 部署配置（唯一模板文件）
# 使用方式:
#   Docker 部署:  cp .env.example .env          → 填写后 ./deploy.sh
#   本地开发:     cp .env.example backend/.env  → 把 DATABASE_URL 改为 localhost 地址
#
# .env 和 backend/.env 均已在 .gitignore 中，绝不提交到代码库
# ============================================================

# ============================================================
# Docker Compose 专属（本地开发时无需关注）
# ============================================================

# 数据库容器密码（与下方 DATABASE_URL 保持一致）
DB_USER=h3c
DB_PASSWORD=change-me-secure-password
DB_NAME=h3c_agent

# 对外端口
WEB_PORT=80
API_PORT=8000

# ============================================================
# Database
# ============================================================
# Docker Compose 部署时此值由 docker-compose.yml 自动覆盖为容器内地址
# 本地开发时填写本机数据库地址
DATABASE_URL=postgresql+asyncpg://h3c:change-me-secure-password@localhost:5432/h3c_agent

# ============================================================
# Auth
# ============================================================
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# 注意: 修改 JWT_SECRET 会导致所有用户 token 失效，且数据库中已加密的 LLM API Key 无法解密
#      上线前轮换的正确顺序: 先显式设置 ENCRYPTION_KEY，再换 JWT_SECRET
JWT_SECRET=change-me-32-plus-random-bytes
JWT_ALG=HS256
# access token 有效期（分钟），前端会自动 refresh
ACCESS_TOKEN_EXPIRE_MINUTES=720
# refresh token 有效期（天），活跃用户每次 refresh 后自动续期
REFRESH_TOKEN_EXPIRE_DAYS=2

# Fernet key，用于加密数据库中存储的模型 API Key（base64 32 字节）
# 生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空 = 从 JWT_SECRET 派生（本地开发可用，生产环境必须显式设置）
ENCRYPTION_KEY=

# ============================================================
# Storage
# ============================================================
# Docker Compose 部署时此三项由 docker-compose.yml 自动覆盖为容器内路径
STORAGE_ROOT=../storage
SKILLS_DIR=../storage/skills
UPLOADS_DIR=../storage/uploads
MAX_UPLOAD_MB=50

# ============================================================
# CORS
# ============================================================
# Docker Compose 部署时此项由 docker-compose.yml 自动根据 APP_BASE_URL 覆盖
# 本地开发时填写前端地址
CORS_ORIGINS=http://localhost:5173

# ============================================================
# 访问地址（用于 CORS 白名单和邮件回链）
# ============================================================
# 填写服务器 IP 或域名，示例:
#   http://192.168.1.100
#   http://192.168.1.100:8080（非标准端口时需加端口）
#   https://agent.example.com
APP_BASE_URL=http://your-server-ip

# ============================================================
# First-run admin（首次登录后立即在管理界面修改密码）
# ============================================================
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-admin-password

# ============================================================
# File parsing (MinerU). Mode: cloud | local | disabled
# ============================================================
MINERU_MODE=cloud
MINERU_BASE_URL=https://mineru.net
# 去 https://mineru.net 注册后申请 API token
MINERU_API_KEY=
MINERU_TIMEOUT_SEC=60
# 文件解析内容长度上限（字符），超出部分取头尾省略中间
PARSED_MARKDOWN_HARD_LIMIT=20000

# ============================================================
# SMTP — 任务通知 / 系统邮件（全部留空则禁用邮件功能）
# ============================================================
# QQ 邮箱配置说明:
#   1. 登录 mail.qq.com → 设置 → 账户 → 开启 IMAP/SMTP 服务
#   2. 按提示验证，系统会生成 16 位授权码（不是 QQ 登录密码）
#   3. 将授权码填入 SMTP_PASSWORD
#   4. SMTP_FROM 中邮箱地址必须与 SMTP_USER 一致（QQ 要求）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# 587 端口用 STARTTLS；改 465 端口需要 SMTP_USE_TLS=false 且 SMTP_USE_SSL=true
SMTP_USE_TLS=true
SMTP_USE_SSL=false
